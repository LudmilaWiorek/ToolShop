{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@pages/*": ["pages/*"],
      "@tests/*": ["tests/*"],
      "@fixtures/*": ["fixtures/*"],
      "@models/*": ["models/*"],
      "@enums/*": ["enums/*"],
      "@factory/*": ["factory/*"],
      "@JSONS/*": ["JSONS/*"],
      "@config/*": ["config/*"],
      "@auth/*": ["auth/*"]
    },
    "types": ["node", "@playwright/test"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true
  }
}
