{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@pages/*": ["./src/pages/*"],
      "@api/*": ["./src/api/*"],
      "@tests/*": ["tests/*"],
      "@fixtures/*": ["./src/fixtures/*"],
      "@models/*": ["./src/models/*"],
      "@enums/*": ["./src/enums/*"],
      "@factories/*": ["./src/factories/*"],
      "@data/*": ["./src/data/*"],
      "@config/*": ["./src/config/*"],
      "@utils/*": ["./src/utils/*"]
    },
    "types": ["node", "@playwright/test"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true
  }
}
